#!/usr/bin/env bash
# Mock curl for install.sh tests. Intercepts -o and the trailing URL, dispatches
# on the URL pattern, and writes the matching fixture content.
set -euo pipefail

OUT=""
URL=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    -o) OUT="$2"; shift 2 ;;
    -f|-s|-S|-L|-fsSL|-fSL|-fL|-sS) shift ;;
    --tlsv1.2|--insecure) shift ;;
    --proto) shift 2 ;;
    --proto=*) shift ;;
    -X) shift 2 ;;
    -H) shift 2 ;;
    -*) shift ;;
    *) URL="$1"; shift ;;
  esac
done

FIXTURES_DIR="$(cd "$(dirname "$0")" && pwd)"

emit() {
  local src="$1"
  if [[ -n "$OUT" ]]; then cp "$src" "$OUT"; else cat "$src"; fi
}

case "$URL" in
  */repos/*/releases)
    emit "${FIXTURES_DIR}/releases.json" ;;
  *.sha256)
    [[ -n "${CURL_404_CHECKSUM:-}" ]] && exit 22
    basename="${URL##*/}"
    binname="${basename%.sha256}"
    if [[ -n "${CURL_BAD_CHECKSUM:-}" ]]; then
      src="${FIXTURES_DIR}/binaries/${binname}.bad-checksum.sha256"
    else
      src="${FIXTURES_DIR}/binaries/${basename}"
    fi
    [[ -f "$src" ]] || exit 22
    emit "$src" ;;
  *sound-cabinet-*-*)
    [[ -n "${CURL_404_BINARY:-}" ]] && exit 22
    basename="${URL##*/}"
    src="${FIXTURES_DIR}/binaries/${basename}"
    [[ -f "$src" ]] || exit 22
    emit "$src" ;;
  *)
    exit 22 ;;
esac
