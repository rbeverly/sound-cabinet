#!/usr/bin/env bash
# Mock curl for install.sh tests. Intercepts -o and the trailing URL, dispatches
# on the URL pattern, and writes the matching fixture content.
set -euo pipefail

OUT=""
URL=""
HEAD=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    -o) OUT="$2"; shift 2 ;;
    -I|--head) HEAD=1; shift ;;
    -f|-s|-S|-L|-fsSL|-fSL|-fL|-sS|-fsSI|-fSI) shift ;;
    --tlsv1.2|--insecure) shift ;;
    --proto) shift 2 ;;
    --proto=*) shift ;;
    -X) shift 2 ;;
    -H) shift 2 ;;
    -*) shift ;;
    *) URL="$1"; shift ;;
  esac
done

FIXTURES_DIR="$(cd "$(dirname "$0")" && pwd)"

emit() {
  local src="$1"
  if [[ -n "$OUT" ]]; then cp "$src" "$OUT"; else cat "$src"; fi
}

# Resolve the archive/checksum file the URL points at (if any) under archives/.
resolve_archive_fixture() {
  local url="$1" basename src
  basename="${url##*/}"
  src="${FIXTURES_DIR}/archives/${basename}"
  echo "$src"
}

case "$URL" in
  */repos/*/releases)
    if [[ $HEAD -eq 1 ]]; then
      printf 'HTTP/1.1 200 OK\n'
      exit 0
    fi
    emit "${FIXTURES_DIR}/releases.json" ;;
  *.tar.gz.sha256|*.zip.sha256)
    [[ -n "${CURL_404_CHECKSUM:-}" ]] && exit 22
    basename="${URL##*/}"
    archive_name="${basename%.sha256}"
    if [[ -n "${CURL_BAD_CHECKSUM:-}" ]]; then
      src="${FIXTURES_DIR}/archives/${archive_name}.bad-checksum.sha256"
    else
      src="${FIXTURES_DIR}/archives/${basename}"
    fi
    [[ -f "$src" ]] || exit 22
    if [[ $HEAD -eq 1 ]]; then
      printf 'HTTP/1.1 200 OK\n'
      exit 0
    fi
    emit "$src" ;;
  *sound-cabinet-*-*.tar.gz|*sound-cabinet-*-*.zip)
    [[ -n "${CURL_404_BINARY:-}" ]] && exit 22
    src=$(resolve_archive_fixture "$URL")
    [[ -f "$src" ]] || exit 22
    if [[ $HEAD -eq 1 ]]; then
      printf 'HTTP/1.1 200 OK\n'
      exit 0
    fi
    emit "$src" ;;
  *)
    exit 22 ;;
esac
